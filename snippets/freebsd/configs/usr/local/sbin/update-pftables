#!/bin/sh -eu
# =============================================================================
# update-pftables
# =============================================================================
#
# Target:
#   FreeBSD 14.0+ (tested with /bin/sh, pfctl, lockf, fetch/curl, awk, sed, grep).
#
# Purpose:
#   Maintain PF tables of "bad hosts" from local logs and remote blocklists.
#   Download, cache, parse, validate, and atomically update PF tables.
#
# Usage:
#   update-pftables [options]
#
# Options:
#   -h, --help                  Show detailed usage and exit.
#   -d, --debug                 Enable debug mode (LOG_LEVEL=3, shorter TTL).
#   -v, --verbose               Set LOG_LEVEL=2 (info).
#   -q, --quiet                 Set LOG_LEVEL=1 (warnings+errors).
#   -l, --log-level N           Set LOG_LEVEL 0..3.
#   -t, --timeout SECONDS       HTTP timeout for downloads. Default 30.
#   -r, --retries N             HTTP retries. Default 3.
#   -j, --threads N             Parallelism for ASN whois. Default 2.
#   --dry-run                   Do not change PF. Show intended actions only.
#   --config FILE               Source config file (sets SOURCES, etc.).
#   --log-format text|json      Log encoding. Default text.
#   --no-color                  Disable ANSI colors on stdout.
#   --self-test                 Run built-in unit tests and exit with status.
#
# Requirements:
#   Required: pfctl, awk, grep, sed, date, file, fetch or curl, whois, lockf.
#   Optional: jq, expiretable, gzip, brotli, zstd, bzip2, xz.
#
# Features:
#   * POSIX sh. FreeBSD-safe temp dirs via mktemp -d -t.
#   * Global single-instance lock via lockf(1). Fallback to mkdir lock.
#   * Structured logging with rotation and compression. Metrics export.
#   * RFC-strict IPv4/IPv6 validation. Local/reserved ranges excluded.
#   * Robust caching with ETag and If-Modified-Since where supported.
#   * Atomic PF updates using `pfctl -T replace -f` per table.
#   * Expiry/TTL via expiretable(8) when available.
#   * Dry-run mode. Built-in unit tests. Clear help.
#
# High-level functions:
#   main                       Orchestrate lifecycle.
#   parse_args                 Parse CLI options.
#   print_usage                Render usage text.
#   validate_input             Check CLI values.
#   validate_dependencies      Check required/optional tools.
#   load_config_file           Source optional config to set SOURCES.
#   with_global_lock           Enforce single instance via lockf or mkdir.
#   rotate_logs_if_needed      Size-based rotation with compression.
#   log, log_metrics           Structured logging and metrics.
#   url_to_safe_name           Map URL to cache-safe basename.
#   convert_to_seconds         Parse TTL strings to seconds.
#   download_file              Fetch with cache and validation.
#   json_extract_key_value     Extract JSON key values to lines.
#   asn_to_ips                 Resolve ASNs to routes via whois.
#   logfile_extract_ips        Extract IPs from log files by patterns.
#   extract_and_filter_ips     Strict RFC IP validation and filtering.
#   table_header/footer        Human-readable section output.
#   table_backup               Backup existing PF table contents.
#   table_process              Normalize and validate input entries.
#   table_update               Diff and replace PF table atomically.
#   self_test                  Minimal unit tests.
#
# Arguments:
#   See Options. No positional arguments.
#
# Returns (exit codes):
#   0  Success.
#   1  Input validation error.
#   2  Dependency missing.
#   3  Download/processing error (non-fatal where possible).
#   4  Lock acquisition failure.
#
# Input:
#   Optional config file; remote or local list sources; system logs.
#
# Output:
#   Logs to stdout and /var/log/update-pftables.log. Metrics to *_metrics.log.
#
# Legal Disclaimer:
#   no warranties for correct function
#
# Last-modified:
#   2025-08-26
#
# Written by:
#   Markus Kohlmeyer and AI
#
# Author:
#   Markus Kohlmeyer <rootservice@gmail.com>
#
# Copyright (c) 2016-2025 Markus Kohlmeyer
#
# MIT License
#
# =============================================================================
#
# Full analyze and explain the code here
# -----------------------------------------------------------------------------
# Design options considered:
#   A) Incremental pfctl -T add per entry with existence checks.
#      Pros: simple diffs, per-entry metrics. Cons: O(n^2) with large tables.
#   B) Bulk atomic update via `pfctl -T replace -f file` after computing diffs.
#      Pros: atomic, fast, scales. Cons: need pre-diff to compute metrics.
#   C) pfctl anchors with include files, then `pfctl -f` to reload ruleset.
#      Pros: very atomic, keeps tables declarative. Cons: touches ruleset.
# Chosen: B. We compute old/new sets, log deltas, then `-T replace`.
#
# Locking options:
#   lockf(1) advisory file locks (fcntl). flock(1) also available on FreeBSD.
#   POSIX semaphores are not directly scriptable in sh; lockf is atomic and
#   sufficient. We use lockf with a child wrapper. Fallback to mkdir lock dir.
#
# Safety:
#   Strict input validation and regexes for RFC-compliant IPs. Reserved ranges
#   excluded. mktemp -d -t with umask 077. Traps cleanup. Dry-run no PF touch.
#
# Performance:
#   Cache+ETag/IMS to avoid downloads. Bulk replace. Sorting once. Parallel
#   whois with xargs -P. Minimal greps. Avoid repeated pfctl show inside loops.
#
# Testing:
#   self_test validates TTL parsing, IPv4/6 filters, diff logic, rotation.
#
# =============================================================================

# =============================================================================
# Global constants and defaults
# =============================================================================
PROG_NAME="$(basename "$0")"                                      # Program name
umask 077                                                         # Secure default perms for created files/dirs

# Secure temp dir on FreeBSD using -t (creates under /tmp with prefix)
TMP_DIR="$(mktemp -d -t "${PROG_NAME}")"                          # Session temp dir

# Caches
CACHE_DIR="/var/cache/${PROG_NAME}"                               # Base cache dir
CACHE_FILES_DIR="${CACHE_DIR}/files"                              # Body cache
CACHE_ETAG_DIR="${CACHE_DIR}/etag"                                # ETag cache

# Behavior toggles
PROVIDE_DEFAULT_SOURCES="1"                                       # Use built-in SOURCES if no config

# RFC-compliant validators
REGEX_IPV4_OCTET='(25[0-5]|2[0-4][0-9]|1?[0-9]{1,2})'             # IPv4 octet 0..255
REGEX_IPV4_FULL="^(${REGEX_IPV4_OCTET}\.${REGEX_IPV4_OCTET}\.${REGEX_IPV4_OCTET}\.${REGEX_IPV4_OCTET})(\/([0-9]|[12][0-9]|3[0-2]))?$"  # IPv4 with optional CIDR
REGEX_IPV4_EXCLUDE='^(0\.|10\.|100\.(6[4-9]|[7-9][0-9]|1[01][0-9]|12[0-7])\.|127\.|169\.254\.|172\.(1[6-9]|2[0-9]|3[01])\.|192\.0\.0\.|192\.0\.2\.|192\.88\.99\.|192\.168\.|198\.(1[89])\.|198\.51\.100\.|203\.0\.113\.|2(2[4-9]|[3-9][0-9])\.|240\.|24[1-9]\.|25[0-5]\.)' # RFC1918+specials
REGEX_IPV6_FULL='^((([0-9A-Fa-f]{1,4}:){7}[0-9A-Fa-f]{1,4}|([0-9A-Fa-f]{1,4}:){1,7}:|([0-9A-Fa-f]{1,4}:){1,6}:[0-9A-Fa-f]{1,4}|([0-9A-Fa-f]{1,4}:){1,5}(:[0-9A-Fa-f]{1,4}){1,2}|([0-9A-Fa-f]{1,4}:){1,4}(:[0-9A-Fa-f]{1,4}){1,3}|([0-9A-Fa-f]{1,4}:){1,3}(:[0-9A-Fa-f]{1,4}){1,4}|([0-9A-Fa-f]{1,4}:){1,2}(:[0-9A-Fa-f]{1,4}){1,5}|[0-9A-Fa-f]{1,4}:((:[0-9A-Fa-f]{1,4}){1,6})|:((:[0-9A-Fa-f]{1,4}){1,7}|:)|(::(ffff(:0{1,4}){0,1}:)?((25[0-5]|2[0-4][0-9]|1?[0-9]{1,2})\.){3}(25[0-5]|2[0-4][0-9]|1?[0-9]{1,2}))|([0-9A-Fa-f]{1,4}:){1,4}:((25[0-5]|2[0-4][0-9]|1?[0-9]{1,2})\.){3}(25[0-5]|2[0-4][0-9]|1?[0-9]{1,2}))))(\/([0-9]|[1-9][0-9]|1[0-1][0-9]|12[0-8]))?$' # IPv6 and CIDR
REGEX_IPV6_EXCLUDE='^(::1$|::$|fc[0-9A-Fa-f]{2}:|fd[0-9A-Fa-f]{2}:|fe[89abAB][0-9A-Fa-f]:|ff[0-9A-Fa-f]{2}:|2001:db8:|2002:|3ffe:)' # RFC4193, multicast, docs, 6to4

# Logging
LOG_LEVEL="2"                                                     # 0=ERROR,1=WARN,2=INFO,3=DEBUG
LOG_FILE="/var/log/${PROG_NAME}.log"                              # Log file path
LOG_FORMAT="text"                                                 # text|json
USE_COLORS=false                                                  # Colorize stdout if tty
[ -t 1 ] && USE_COLORS=true                                       # Enable colors when stdout is a TTY
MAX_LOG_SIZE_BYTES="1048576"                                      # 1 MiB rotate threshold
METRICS_FILE="/var/log/${PROG_NAME}_metrics.log"                  # Metrics output

# Behavior knobs
DEBUG_MODE=false                                                  # Debug toggle
TABLE_DEFAULT_EXPIRE="86400"                                      # Default expire seconds
DOWNLOAD_TIMEOUT="30"                                             # HTTP timeout seconds
DOWNLOAD_RETRIES="3"                                              # HTTP retries
PROCESSING_THREADS="2"                                            # Parallel whois requests
DRY_RUN=false                                                     # Do not change PF when true
CONFIG_FILE="/usr/local/etc/${PROG_NAME}.conf"                    # Config file path
LOCK_FILE="/var/run/${PROG_NAME}.lock"                            # Single-instance lock file
WHOIS_POLITE_DELAY_SECONDS="1"                                    # Delay between whois calls
MY_OWN_IPS="/etc/pf.internal"                                     # Local IPs to exclude
START_TS="$(date -j -v-24H '+%Y%m%d%H%M%S')"                      # Log scan window start (UTC)
# Variable naming rule: "Variable names are uppercased if the variable is read-only or if it is an external variable."  # Rule statement for uppercase vars

# Default sources (used when no config overrides SOURCES)
DEFAULT_SOURCES='
badhosts_priv|file:///etc/pf.badhosts_priv|30d|plain
badhosts_http|file:///etc/pf.badhosts_http|7d|plain
badhosts_mail|file:///var/log/maillog|2d|mail_awk
badhosts_sshd|file:///var/log/auth.log|6h|sshd_awk
badhosts_drop|https://www.spamhaus.org/drop/drop_v4.json|90d|json_cidr
badhosts_drop|https://www.spamhaus.org/drop/drop_v6.json|90d|json_cidr
badhosts_drop|https://www.spamhaus.org/drop/asndrop.json|90d|json_asn
badhosts_torp|https://www.dan.me.uk/torlist/?full|2d|plain
badhosts_misc|https://lists.blocklist.de/lists/all.txt|2d|plain
'                                                                  # Pipe-delimited: table|url|expire|processor

# Pattern sets for log extraction
mail_awk_rules='
DNSBL rank
'                                                                  # Mail log markers
sshd_awk_rules='
reverse mapping checking getaddrinfo for
Did not receive identification string from
Bad protocol version identification
banner exchange: Connection from
Unable to negotiate with
Connection closed by
Connection reset by
Failed password for
Invalid user
'                                                                  # SSHD log markers

# =============================================================================
# log
# =============================================================================
# Purpose:
#   Structured logging with levels and optional colors. Rotates logs when needed.
# Arguments:
#   $1 level (0..3), $* message.
# Returns (exit codes):
#   0 always.
# Input:
#   LOG_LEVEL, LOG_FORMAT, LOG_FILE, USE_COLORS.
# Output:
#   stdout (colored) and log file; JSON or text.
# Notes:
#   rotate_logs_if_needed called for text logs.
# =============================================================================
log() {
  level="${1}"; shift                                            # Extract level
  if [ "${level}" -le "${LOG_LEVEL}" ]; then                     # Level gate
    case "${level}" in 0) msg_type="ERROR" ;; 1) msg_type="WARN " ;; 2) msg_type="INFO " ;; 3) msg_type="DEBUG" ;; esac  # Label
    if [ "${USE_COLORS}" = true ]; then                          # Color branch
      case "${level}" in 0) color="\033[1;31m" ;; 1) color="\033[1;33m" ;; 2) color="\033[1;36m" ;; 3) color="\033[1;35m" ;; esac  # ANSI
      reset_color="\033[0m"                                      # Reset
    else
      color=""; reset_color=""                                   # No color
    fi
    timestamp="$(date '+%Y-%m-%d %H:%M:%S')"                     # ISO-like ts
    message="${*}"                                               # Message body
    if [ "${LOG_FORMAT}" = "json" ]; then                        # JSON branch
      printf '{"timestamp":"%s","level":"%s","message":"%s"}\n' "${timestamp}" "${msg_type}" "${message}" >> "${LOG_FILE}"  # Append JSON log
    else                                                         # Text branch
      rotate_logs_if_needed                                      # Rotate if big
      printf "%s %s%s%s: %s\n" "${timestamp}" "${color}" "${msg_type}" "${reset_color}" "${message}" | tee -a "${LOG_FILE}"  # Echo+append
    fi
  fi
}

# =============================================================================
# log_metrics
# =============================================================================
# Purpose:
#   Write metrics in text or JSON.
# Arguments:
#   $* metric text.
# Returns:
#   0.
# =============================================================================
log_metrics() {
  timestamp="$(date '+%Y-%m-%d %H:%M:%S')"                        # Timestamp
  rotate_logs_if_needed                                           # Rotate metrics too
  if [ "${LOG_FORMAT}" = "json" ]; then                           # JSON or text
    printf '{"timestamp":"%s","type":"metrics","data":"%s"}\n' "${timestamp}" "${*}" >> "${METRICS_FILE}"  # JSON metrics
  else
    printf "%s: %s\n" "${timestamp}" "${*}" >> "${METRICS_FILE}"  # Text metrics
  fi
}

# =============================================================================
# rotate_logs_if_needed
# =============================================================================
# Purpose:
#   Rotate log and metrics when exceeding MAX_LOG_SIZE_BYTES. Compress rotated.
# =============================================================================
rotate_logs_if_needed() {
  for f in "${LOG_FILE}" "${METRICS_FILE}"; do                   # Iterate files
    [ -f "${f}" ] || continue                                    # Skip missing
    size_bytes="$(wc -c < "${f}" 2>/dev/null || echo 0)"         # Size or 0
    case "${size_bytes}" in ''|*[!0-9]*) continue ;; esac        # Guard numeric
    if [ "${size_bytes}" -ge "${MAX_LOG_SIZE_BYTES}" ]; then     # Threshold
      ts="$(date '+%Y%m%d%H%M%S')"                               # Suffix
      rotated="${f}.${ts}"                                       # Rotated name
      mv -f "${f}" "${rotated}" 2>/dev/null || continue          # Move aside
      : > "${f}"                                                 # Truncate new
      if command -v gzip >/dev/null 2>&1; then                   # Compress if avail
        gzip -9f "${rotated}" >/dev/null 2>&1 || true            # Best effort
      fi
    fi
  done
}

# =============================================================================
# with_global_lock
# =============================================================================
# Purpose:
#   Ensure single instance via lockf(1). Fallback to mkdir lock dir semantics.
# Arguments:
#   $@ command to execute while holding lock.
# Notes:
#   lockf uses fcntl advisory locks (atomic). If unavailable, mkdir fallback.
# =============================================================================
with_global_lock() {
  if command -v lockf >/dev/null 2>&1; then                      # Prefer lockf
    # Run the provided command under lockf. Non-blocking to exit fast if locked.
    lockf -t 0 -k "${LOCK_FILE}" "$@"                             # Acquire, run, release
    return "$?"                                                   # Propagate rc
  fi
  # Fallback mkdir lock (atomic create). Clean up on exit.
  LOCK_DIR="${LOCK_FILE}.d"                                      # Fallback dir
  if mkdir "${LOCK_DIR}" 2>/dev/null; then                       # Try to lock
    trap 'rm -rf "${LOCK_DIR}" >/dev/null 2>&1 || true' EXIT INT TERM HUP  # Cleanup
    "$@"                                                         # Run payload
    rc="$?"                                                      # Capture rc
    rm -rf "${LOCK_DIR}" >/dev/null 2>&1 || true                 # Remove lock
    trap - EXIT INT TERM HUP                                     # Clear traps
    return "${rc}"                                               # Return rc
  else
    log 1 "Another instance appears to be running (lock: ${LOCK_FILE})"  # Warn
    return 4                                                     # Lock error
  fi
}

# =============================================================================
# url_to_safe_name
# =============================================================================
# Purpose: Map URL to cache-safe file stem (bounded length).
# =============================================================================
url_to_safe_name() {
  url="${1}"                                                     # Input URL
  safe="$(printf '%s' "${url}" | sed -e 's/[^A-Za-z0-9._-]/_/g')" # Replace unsafe
  printf '%s' "$(printf '%s' "${safe}" | cut -c1-180)"           # Bound length
}

# =============================================================================
# extract_and_filter_ips
# =============================================================================
# Purpose:
#   From arbitrary text lines, extract candidates, validate IPv4/IPv6(+CIDR),
#   exclude reserved/doc ranges, and print valid entries.
# =============================================================================
extract_and_filter_ips() {
  while IFS= read -r line; do                                    # Read line
    echo "${line}" | grep -E -q '^[[:space:]]*[#;]' && continue  # Skip comments
    candidate="$(printf '%s' "${line}" | sed -e 's/^.*[\[<({]\([^]\[<>{)}]*\)[\]>) }].*$/\1/g' -e 's/^.*"\([^"]*\)".*$/\1/g' -e "s/[\",;:()]\$//" -e 's/^[[:space:]]*//;s/[[:space:]]*$//')"  # Try bracket/quote extract
    [ -z "${candidate}" ] && candidate="$(printf '%s' "${line}" | awk '{print $1}')"  # Fallback field 1
    set -- "$(printf '%s' "${candidate}" | tr ',;' '  ')"        # Tokenize delimiters
    for token in "$@"; do                                        # Iterate tokens
      token="$(printf '%s' "${token}" | sed -e "s/[\",;:()'\`]$//" -e 's/^[[:space:]]*//;s/[[:space:]]*$//')"  # Trim junk
      [ -z "${token}" ] && continue                              # Skip empty
      if printf '%s' "${token}" | grep -E -q '/'; then           # CIDR path
        if printf '%s' "${token}" | grep -E -q '^([0-9]+\.){3}[0-9]+\/[0-9]+$'; then  # IPv4/CIDR shape
          ip_part="$(printf '%s' "${token}" | cut -d/ -f1)"      # IP
          prefix="$(printf '%s' "${token}" | cut -d/ -f2)"       # Prefix
          if printf '%s' "${ip_part}" | grep -E -q '^'"${REGEX_IPV4_OCTET}"'\.'"${REGEX_IPV4_OCTET}"'\.'"${REGEX_IPV4_OCTET}"'\.'"${REGEX_IPV4_OCTET}"'$' && printf '%s' "${prefix}" | grep -E -q '^[0-9]+$' && [ "${prefix}" -ge 0 ] 2>/dev/null && [ "${prefix}" -le 32 ] 2>/dev/null; then  # Valid IPv4 CIDR
            echo "${token}"                                      # Emit
          fi
        elif printf '%s' "${token}" | grep -E -q ':'; then       # IPv6 CIDR shape
          prefix="$(printf '%s' "${token}" | awk -F/ '{print $2}')" # IPv6 prefix
          if printf '%s' "${prefix}" | grep -E -q '^[0-9]+$' && [ "${prefix}" -ge 0 ] 2>/dev/null && [ "${prefix}" -le 128 ] 2>/dev/null; then  # Valid prefix
            echo "${token}"                                      # Emit
          fi
        fi
      else                                                        # Non-CIDR
        if printf '%s' "${token}" | grep -E -q '^([0-9]+\.){3}[0-9]+$'; then  # IPv4 shape
          if printf '%s' "${token}" | grep -E -q '^'"${REGEX_IPV4_OCTET}"'\.'"${REGEX_IPV4_OCTET}"'\.'"${REGEX_IPV4_OCTET}"'\.'"${REGEX_IPV4_OCTET}"'$' && ! printf '%s' "${token}" | grep -E -q "${REGEX_IPV4_EXCLUDE}"; then  # Valid and not excluded
            echo "${token}"                                      # Emit
          fi
        elif printf '%s' "${token}" | grep -E -q ':'; then       # IPv6 shape
          if printf '%s' "${token}" | grep -E -q "${REGEX_IPV6_FULL}" && ! printf '%s' "${token}" | grep -E -q "${REGEX_IPV6_EXCLUDE}"; then  # Valid and not excluded
            echo "${token}"                                      # Emit
          fi
        fi
      fi
    done
  done
}

# =============================================================================
# download_file
# =============================================================================
# Purpose:
#   Retrieve URL to output_file with caching (ETag/IMS). Supports file://.
# =============================================================================
download_file() {
  url="${1}"; output_file="${2}"; table_name="${3}"              # Inputs
  log 3 "Downloading file from: ${url}"                           # Debug
  tempfile="$(mktemp "${TMP_DIR}/download_file_raw.XXXXXX")"      # Temp body
  _dl_cleanup() { rm -f "${tempfile}" >/dev/null 2>&1 || true; }  # Scoped cleanup
  safe="$(url_to_safe_name "${url}")"                             # Cache key
  cached_file="${CACHE_FILES_DIR}/${safe}.cache"                  # Cache body
  etag_file="${CACHE_ETAG_DIR}/${safe}.etag"                      # Cache ETag
  if echo "${url}" | grep -E -q '^file://'; then                  # Local file
    file_path="$(echo "${url}" | sed 's|^file://||g')"            # Path extract
    if [ ! -f "${file_path}" ]; then                              # Existence check
      _dl_cleanup                                                # Cleanup
      log 0 "Error: File not found: ${file_path}"                 # Error
      return 3                                                    # Failure
    fi
    cp -f "${file_path}" "${tempfile}"                            # Copy
  elif echo "${url}" | grep -E -q '^https?://'; then              # HTTP(S)
    attempt="1"                                                   # Attempt counter
    while [ "${attempt}" -le "${DOWNLOAD_RETRIES}" ]; do          # Retry loop
      if command -v curl >/dev/null 2>&1; then                    # Use curl
        http_code="$(curl --silent --show-error --output "${tempfile}" --write-out "%{http_code}" --max-time "${DOWNLOAD_TIMEOUT}" --connect-timeout 10 --tlsv1.2 --http2 --location --compressed --ignore-content-length --user-agent "Mozilla/5.0 (FreeBSD 14.0; rv:143.0)" --header "Accept: */*" --header "Accept-Encoding: gzip, deflate, br, zstd" $( [ -f "${etag_file}" ] && printf -- '--etag-compare %s' "${etag_file}" ) $( [ -n "${etag_file}" ] && printf -- '--etag-save %s' "${etag_file}" ) $( [ -f "${cached_file}" ] && printf -- '-z %s' "${cached_file}" ) --remote-time "${url}" 2>&1 )" || http_code="000"  # Fetch
        case "${http_code}" in                                    # Handle code
          200|201|202|203|204)
            mv -f "${tempfile}" "${cached_file}" 2>/dev/null || cp -f "${tempfile}" "${cached_file}"  # Update cache
            cp -f "${cached_file}" "${output_file}"               # Deliver
            log 2 "Downloaded and cached: ${url} (HTTP ${http_code})"  # Info
            _dl_cleanup                                           # Clean
            return 0                                              # OK
            ;;
          304)
            if [ -f "${cached_file}" ]; then                      # Use cache
              cp -f "${cached_file}" "${output_file}"             # Deliver
              log 2 "Not modified: used cached copy for ${url}"   # Info
              _dl_cleanup                                         # Clean
              return 0                                            # OK
            else
              log 1 "Warning: 304 but no local cache present; retrying"  # Warn
              attempt="$((attempt + 1))"                          # Next
              sleep 1                                             # Backoff
              continue                                            # Loop
            fi
            ;;
          000)
            log 1 "curl error while fetching ${url}"              # Warn
            ;;
          *)
            log 1 "HTTP ${http_code} while fetching ${url}"       # Warn
            ;;
        esac
      elif command -v fetch >/dev/null 2>&1; then                 # Use fetch
        if [ -f "${cached_file}" ]; then                          # IMS path
          if fetch -i "${cached_file}" -o "${tempfile}" -q "${url}"; then  # Fetch IMS
            if [ -s "${tempfile}" ]; then                         # New body
              mv -f "${tempfile}" "${cached_file}" 2>/dev/null || cp -f "${tempfile}" "${cached_file}"  # Update cache
              cp -f "${cached_file}" "${output_file}"             # Deliver
              log 2 "Fetched (with IMS) and cached: ${url}"       # Info
              _dl_cleanup                                         # Clean
              return 0                                            # OK
            else
              if [ -f "${cached_file}" ]; then                    # Not modified
                cp -f "${cached_file}" "${output_file}"           # Deliver
                log 2 "Fetch returned not-modified; used cached copy for ${url}"  # Info
                _dl_cleanup                                       # Clean
                return 0                                          # OK
              fi
            fi
          else
            log 1 "fetch failed for ${url}"                       # Warn
          fi
        else
          if fetch -o "${tempfile}" -q "${url}"; then             # First-time
            if [ -s "${tempfile}" ]; then                         # Has body
              mv -f "${tempfile}" "${cached_file}" 2>/dev/null || cp -f "${tempfile}" "${cached_file}"  # Cache
              cp -f "${cached_file}" "${output_file}"             # Deliver
              log 2 "Fetched and cached: ${url}"                  # Info
              _dl_cleanup                                         # Clean
              return 0                                            # OK
            fi
          else
            log 1 "fetch failed for ${url}"                       # Warn
          fi
        fi
      else
        _dl_cleanup                                               # Clean
        log 0 "Error: No download utility available (curl or fetch)"  # Error
        return 3                                                  # Fail
      fi
      if [ "${attempt}" -eq "${DOWNLOAD_RETRIES}" ]; then         # Final attempt
        _dl_cleanup                                               # Clean
        log 0 "Error: Failed to download after ${DOWNLOAD_RETRIES} attempts: ${url}"  # Error
        return 3                                                  # Fail
      fi
      attempt="$((attempt + 1))"                                  # Next
      sleep 1                                                     # Backoff
    done
  else
    _dl_cleanup                                                   # Clean
    log 0 "Error: Invalid URL scheme for download: ${url}"        # Error
    return 3                                                      # Fail
  fi
  if [ -s "${tempfile}" ]; then                                   # Fallback if body present
    mv -f "${tempfile}" "${output_file}"                          # Deliver
    _dl_cleanup                                                   # Clean
    log 2 "Downloaded (fallback) and saved: ${url}"               # Info
    return 0                                                      # OK
  fi
  _dl_cleanup                                                     # Clean
  log 1 "Warning: No data retrieved for ${url}"                   # Warn
  return 3                                                        # Soft fail
}

# =============================================================================
# convert_to_seconds
# =============================================================================
# Purpose: Convert strings like 30s, 5m, 2h, 7d to seconds. Empty -> default.
# =============================================================================
convert_to_seconds() {
  expire_time="${1}"                                             # Input string
  if [ -z "${expire_time}" ]; then                               # Empty
    echo "${TABLE_DEFAULT_EXPIRE}"                                # Default
    return 0                                                     # OK
  fi
  number="$(echo "${expire_time}" | sed 's/[^0-9]//g')"          # Digits
  unit="$(echo "${expire_time}" | sed 's/[0-9]*//g')"            # Suffix
  if [ -z "${number}" ] || ! echo "${number}" | grep -E -q '^[0-9]+$'; then  # Guard
    echo "${TABLE_DEFAULT_EXPIRE}"                                # Default
    return 0                                                     # OK
  fi
  case "${unit}" in                                              # Compute
    d) result="$((number * 24 * 60 * 60))" ;;                    # Days
    h) result="$((number * 60 * 60))" ;;                         # Hours
    m) result="$((number * 60))" ;;                              # Minutes
    s) result="${number}" ;;                                     # Seconds
    "") result="${number}" ;;                                    # Plain seconds
    *) result="${TABLE_DEFAULT_EXPIRE}" ;;                       # Fallback
  esac
  echo "${result}"                                               # Emit
}

# =============================================================================
# logfile_extract_ips
# =============================================================================
# Purpose:
#   Grep-like extraction from logs limited to recent lines and patterns.
#   Excludes own IPs and reserved ranges. Outputs unique IPs.
# =============================================================================
logfile_extract_ips() {
  input_file="${1}"; output_file="${2}"; shift 2; search_strings="${*}"  # Inputs
  awk -v selfips="${MY_OWN_IPS}" -v start_ts="${START_TS}" -v search="${search_strings}" '
BEGIN {
  while ((getline ip < selfips) > 0) { self[ip] = 1 }            # Load own IPs
  close(selfips)                                                 # Close file
  mon["Jan"]="01"; mon["Feb"]="02"; mon["Mar"]="03"; mon["Apr"]="04"; mon["May"]="05"; mon["Jun"]="06"
  mon["Jul"]="07"; mon["Aug"]="08"; mon["Sep"]="09"; mon["Oct"]="10"; mon["Nov"]="11"; mon["Dec"]="12"  # Month map
  n = split(search, sarr, " ")                                   # Patterns
}
{
  line = $0                                                      # Copy line
  matched = 0                                                    # Flag
  for(i=1;i<=n;i++){ if(index(line,sarr[i])) { matched=1; break } }  # Any pattern
  if(!matched) next                                              # Skip if none
  if (match(line, "^(Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec) [0-9]{1,2} [0-9]{2}:[0-9]{2}:[0-9]{2}")) {
    month = substr(line,RSTART,3); day = substr(line,RSTART+4,2); hh = substr(line,RSTART+7,2); mm = substr(line,RSTART+10,2); ss = substr(line,RSTART+13,2); gsub(/^ /, "", day) # Parse ts
    cmd = "date +%Y"; cmd | getline year; close(cmd)             # Year
    ts = year mon[month] day hh mm ss                             # Compose ts
    if(ts < start_ts) next                                       # Too old
  }
  gsub(/\b(Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec) [0-9]{1,2}\b/," ", line); gsub(/[0-9]{2}:[0-9]{2}:[0-9]{2}/," ", line)  # Strip time words
  while(match(line,"\\[?[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}\\]?")) {  # IPv4 scan
    ip = substr(line,RSTART,RLENGTH); gsub(/^\[|\]$/,"",ip)      # Normalize
    rest = substr(line,RSTART+RLENGTH,1)                         # Next char
    if(rest~/^[0-9.]$/){ line=substr(line,RSTART+RLENGTH); continue }  # Avoid overlapping
    split(ip,o,"."); if(o[1]>255||o[2]>255||o[3]>255||o[4]>255){ line=substr(line,RSTART+RLENGTH); continue } # Range check
    if(o[1]==10||o[1]==127||(o[1]==169&&o[2]==254)||(o[1]==172&&o[2]>=16&&o[2]<=31)||(o[1]==192&&o[2]==168)||o[1]==0||o[1]>=224||ip in self){ line=substr(line,RSTART+RLENGTH); continue } # Exclude
    print ip; line=substr(line,RSTART+RLENGTH)                   # Emit
  }
  while(match(line,"\\[?[0-9A-Fa-f]{1,4}:[0-9A-Fa-f:]+\\]?")) {  # IPv6 scan
    raw=substr(line,RSTART,RLENGTH); gsub(/^\[|\]$/,"", raw)     # Normalize
    after=substr(line,RSTART+RLENGTH,2)                          # Next chars
    if(after~/^:[0-9]/){ line=substr(line,RSTART+RLENGTH); continue } # Avoid ports
    ip=raw; low=tolower(ip)                                      # Copy
    if(index(ip,":")==0){ line=substr(line,RSTART+RLENGTH); continue } # Must have :
    n=split(ip,parts,":"); double_colon=(ip~/::/); valid=1       # Heuristics
    if(n>8&&!double_colon){ valid=0 }                            # Basic check
    for(i=1;i<=n;i++){ if(parts[i]=="") continue; if(length(parts[i])>4||parts[i]!~/^[0-9a-fA-F]+$/){ valid=0; break } } # Hex check
    if(!valid){ line=substr(line,RSTART+RLENGTH); continue }     # Skip invalid
    if(low=="::1"||low=="::"||low~/^fc[0-9a-f]/||low~/^fd[0-9a-f]/||low~/^fe[89ab][0-9a-f]/||low~/^ff[0-9a-f]/||ip in self){ line=substr(line,RSTART+RLENGTH); continue } # Exclude
    print ip; line=substr(line,RSTART+RLENGTH)                   # Emit
  }
}
' "${input_file}" | sort -bu > "${output_file}"                   # Unique sort
}

# =============================================================================
# json_extract_key_value
# =============================================================================
# Purpose: Extract .cidr or .asn array/object values from JSON using jq or awk.
# =============================================================================
json_extract_key_value() {
  input_file="${1}"; output_file="${2}"; key_value="${3}"        # Inputs
  if [ ! -f "${input_file}" ]; then                               # Guard
    log 1 "Error: JSON file not found: ${input_file}"             # Warn
    return 1                                                      # Fail
  fi
  if command -v jq >/dev/null 2>&1; then                          # Prefer jq
    if ! jq empty "${input_file}" 2>/dev/null; then               # Validate JSON
      log 1 "Error: Invalid JSON file: ${input_file}"             # Warn
      return 1                                                    # Fail
    fi
    jq -r --arg k "${key_value}" '
      if type=="array" then
        .[] | (if has($k) then .[$k] else empty end)
      elif type=="object" then
        (if has($k) then .[$k] else empty end)
      else empty end
    ' "${input_file}" > "${output_file}"                           # Extract
  else
    log 2 "Optional jq not found, using awk for basic JSON parsing" # Info
    awk -v key="${key_value}" -F'"' '{ for (i = 1; i <= NF; i++) { if ($i == key) { print $(i+2) } } }' "${input_file}" > "${output_file}"  # Heuristic
  fi
  if [ ! -s "${output_file}" ]; then                               # Any values?
    log 1 "Warning: No values found for key '${key_value}' in ${input_file}" # Warn
    return 1                                                       # Soft fail
  fi
  return 0                                                         # OK
}

# =============================================================================
# asn_to_ips
# =============================================================================
# Purpose: Convert ASNs (lines like AS1234) to route prefixes via RADB whois.
# =============================================================================
asn_to_ips() {
  input_file="${1}"                                              # ASN list
  output_file="${2}"                                             # Output routes
  log 3 "Converting AS numbers to IPs: ${input_file}"            # Debug
  if [ ! -f "${input_file}" ]; then                               # Guard
    log 2 "No input file for ASN conversion: ${input_file}"       # Info
    : > "${output_file}"                                          # Empty out
    return 0                                                      # OK
  fi
  temp_result="${TMP_DIR}/asn_to_ips_result.txt"                  # Temp output
  : > "${temp_result}"                                            # Truncate
  grep -E '^AS[0-9]+' "${input_file}" 2>/dev/null | \
  xargs -n1 -P"${PROCESSING_THREADS}" sh -c '
    asn="${1}"; outtmp="${2}"; delay="${3:-1}"                   # Inputs in subshell
    [ -z "${asn}" ] && exit 0                                    # Guard empty
    whois -h whois.radb.net -- "-i origin ${asn}" 2>/dev/null | awk "/^route/ { print \$2 }" >> "${outtmp}" 2>/dev/null || true  # Query and append
    sleep ${delay}                                               # Polite delay
  ' _{} "${temp_result}" "${WHOIS_POLITE_DELAY_SECONDS}" || true  # Launch
  if [ -s "${temp_result}" ]; then                                # Any results
    sort -u "${temp_result}" > "${output_file}"                   # Unique
    rm -f "${temp_result}"                                        # Clean
    log 2 "Converted AS numbers to IPs: $(wc -l < "${output_file}") entries"  # Info
    return 0                                                      # OK
  else
    log 1 "No IP addresses found for AS numbers in ${input_file}" # Warn
    : > "${output_file}"                                          # Empty
    return 1                                                      # Soft fail
  fi
}

# =============================================================================
# table_header / table_footer / table_backup
# =============================================================================
table_header() {
  table_name="${1}"; log 2 "================================================================================"; log 2 "Table ${table_name}"; log 2 "================================================================================"  # Section banner
}
table_backup() {
  table_name="${1}"; backup_file="${TMP_DIR}/${table_name}.backup" # Backup path
  if pfctl -t "${table_name}" -T show > "${backup_file}" 2>/dev/null; then  # Dump
    count="$(wc -l < "${backup_file}")"                           # Count
    log 2 "Backup created with ${count} entries for table: ${table_name}"  # Info
  else
    : > "${backup_file}"                                          # Empty
    log 2 "Empty backup created for table: ${table_name} (table might not exist)" # Info
  fi
}
table_footer() {
  table_name="${1}"                                               # Name
  log 2 ""                                                        # Spacer
  if pfctl -t "${table_name}" -v -T show >/dev/null 2>&1; then    # Exists?
    count="$(pfctl -t "${table_name}" -T show | wc -l)"           # Count
    log 2 "Final status for table ${table_name}: ${count} entries" # Info
  else
    log 2 "Table ${table_name} has no entries or does not exist"  # Info
  fi
  log 2 ""                                                        # Spacer
  log 2 "================================================================================"  # End banner
}

# =============================================================================
# table_process
# =============================================================================
# Purpose:
#   Normalize raw source into a validated list of IPs/CIDRs for a table.
# =============================================================================
table_process() {
  table_name="${1}"; input_file="${2}"                            # Inputs
  log 3 "Processing table: ${table_name} from input: ${input_file}" # Debug
  if [ ! -f "${input_file}" ]; then                               # Guard
    log 2 "Input file not found for processing: ${input_file}"    # Info
    : > "${TMP_DIR}/${table_name}"                                # Empty out
    return 0                                                      # OK
  fi
  : > "${TMP_DIR}/${table_name}"                                   # Truncate
  while IFS= read -r candidate; do                                 # Read lines
    printf '%s\n' "${candidate}" | extract_and_filter_ips | while IFS= read -r ip; do  # Validate and iterate
      if printf '%s' "${ip}" | grep -E -q '^([0-9]+\.){3}[0-9]+(\/[0-9]+)?$'; then    # IPv4 or IPv4/CIDR
        ipaddr="$(printf '%s' "${ip}" | cut -d/ -f1)"             # Base IP
        prefix="$(printf '%s' "${ip}" | grep -q / && printf '%s' "${ip}" | cut -d/ -f2 || printf '%s' "")"  # Prefix if any
        if printf '%s' "${ipaddr}" | grep -E -q '^'"${REGEX_IPV4_OCTET}"'\.'"${REGEX_IPV4_OCTET}"'\.'"${REGEX_IPV4_OCTET}"'\.'"${REGEX_IPV4_OCTET}"'$'; then  # Valid octets
          if [ -n "${prefix}" ]; then                             # CIDR path
            if [ "${prefix}" -ge 0 ] 2>/dev/null && [ "${prefix}" -le 32 ] 2>/dev/null; then  # Valid prefix
              printf '%s\n' "${ip}" >> "${TMP_DIR}/${table_name}" # Emit
            fi
          else
            if ! printf '%s' "${ip}" | grep -E -q "${REGEX_IPV4_EXCLUDE}"; then  # Exclude RFC1918
              printf '%s\n' "${ip}" >> "${TMP_DIR}/${table_name}" # Emit
            fi
          fi
        fi
      elif printf '%s' "${ip}" | grep -E -q ':'; then             # IPv6 path
        if printf '%s' "${ip}" | grep -E -q "${REGEX_IPV6_FULL}" && ! printf '%s' "${ip}" | grep -E -q "${REGEX_IPV6_EXCLUDE}"; then  # Valid
          printf '%s\n' "${ip}" >> "${TMP_DIR}/${table_name}"     # Emit
        else
          if printf '%s' "${ip}" | grep -E -q '/[0-9]+$'; then    # Loose CIDR
            prefix="$(printf '%s' "${ip}" | awk -F/ '{print $2}')" # Prefix
            if [ "${prefix}" -ge 0 ] 2>/dev/null && [ "${prefix}" -le 128 ] 2>/dev/null; then  # Valid
              printf '%s\n' "${ip}" >> "${TMP_DIR}/${table_name}" # Emit
            fi
          fi
        fi
      fi
    done
  done < "${input_file}"                                          # End read
  if [ -s "${TMP_DIR}/${table_name}" ]; then                      # Any entries
    sort -u "${TMP_DIR}/${table_name}" -o "${TMP_DIR}/${table_name}" # Unique in place
    count="$(wc -l < "${TMP_DIR}/${table_name}")"                 # Count
    log 2 "Processed ${count} IP/CIDR entries for table: ${table_name}"  # Info
  else
    log 2 "No valid IP/CIDR entries found in input file for table: ${table_name}"  # Info
  fi
}

# =============================================================================
# table_update
# =============================================================================
# Purpose:
#   Compute diff vs current table and atomically replace contents. Apply TTL.
# =============================================================================
table_update() {
  table_name="${1}"; expire_time_str="${2}"                       # Inputs
  log 3 "Updating table: ${table_name} with expiration: ${expire_time_str}"  # Debug
  new_file="${TMP_DIR}/${table_name}"                             # New set
  old_file="${TMP_DIR}/${table_name}.current"                     # Old set snapshot
  : > "${old_file}"                                               # Truncate
  pfctl -t "${table_name}" -T show > "${old_file}" 2>/dev/null || :  # Snapshot old (may be empty)
  # Compute diffs for metrics
  new_sorted="${TMP_DIR}/${table_name}.new.sorted"                # New sorted
  old_sorted="${TMP_DIR}/${table_name}.old.sorted"                # Old sorted
  sort -u "${new_file}" -o "${new_sorted}" 2>/dev/null || :       # Ensure sorted
  sort -u "${old_file}" -o "${old_sorted}" 2>/dev/null || :       # Ensure sorted
  added_count="$(comm -13 "${old_sorted}" "${new_sorted}" 2>/dev/null | wc -l | awk '{print $1}')"  # New only
  removed_count="$(comm -23 "${old_sorted}" "${new_sorted}" 2>/dev/null | wc -l | awk '{print $1}')" # Removed only
  same_count="$(comm -12 "${old_sorted}" "${new_sorted}" 2>/dev/null | wc -l | awk '{print $1}')"    # Unchanged
  total_new="$(wc -l < "${new_sorted}" 2>/dev/null || echo 0)"    # Totals
  if [ "${DRY_RUN}" = true ]; then                                # Dry-run
    log 2 "DRY RUN - Would replace ${table_name}: total=${total_new}, +${added_count}, -${removed_count}, =${same_count}"  # Report
    return 0                                                      # Skip apply
  fi
  # Replace atomically
  if [ -s "${new_sorted}" ]; then                                 # Has entries
    pfctl -t "${table_name}" -T replace -f "${new_sorted}" 2>/dev/null || pfctl -t "${table_name}" -T add -f "${new_sorted}" 2>/dev/null  # Replace or create
  else
    pfctl -t "${table_name}" -T kill 2>/dev/null || true          # Empty table if none
  fi
  expire_time="$(convert_to_seconds "${expire_time_str}")"         # TTL seconds
  log_metrics "TABLE_UPDATE:${table_name}:TOTAL=${total_new}:ADDED=${added_count}:REMOVED=${removed_count}:UNCHANGED=${same_count}:EXPIRE_TIME=${expire_time}"  # Metrics
  if command -v expiretable >/dev/null 2>&1; then                  # Prefer expiretable
    expiretable -v -t "${expire_time}" "${table_name}" 2>/dev/null || true  # Apply TTL
  else
    pfctl -t "${table_name}" -T expire "${expire_time}" 2>/dev/null || true # PF native expire
  fi
  log 2 "Table update completed for ${table_name}. total=${total_new}, +${added_count}, -${removed_count}, =${same_count}"  # Info
}

# =============================================================================
# print_usage
# =============================================================================
# Purpose: Print detailed usage including processors and examples.
# =============================================================================
print_usage() {
  cat <<EOF
Usage: ${PROG_NAME} [OPTIONS]

Options:
  -h, --help                  Show this help and exit.
  -d, --debug                 Enable debug mode (LOG_LEVEL=3, expire=1h).
  -v, --verbose               Info logging.
  -q, --quiet                 Warnings and errors only.
  -l, --log-level N           Set log level 0..3.
  -t, --timeout SECONDS       HTTP timeout (default ${DOWNLOAD_TIMEOUT}).
  -r, --retries N             HTTP retries (default ${DOWNLOAD_RETRIES}).
  -j, --threads N             Parallel whois (default ${PROCESSING_THREADS}).
  --dry-run                   Do not modify PF.
  --config FILE               Source config file.
  --log-format text|json      Log encoding (default ${LOG_FORMAT}).
  --no-color                  Disable ANSI colors on stdout.
  --self-test                 Run unit tests.

Processors:
  plain       Raw lines with IPs or CIDRs.
  json_cidr   Extract key "cidr" from JSON.
  json_asn    Extract "asn" numbers and resolve to routes.
  mail_awk    Extract IPs from mail log patterns.
  sshd_awk    Extract IPs from sshd log patterns.

SOURCES entry format (pipe-delimited):
  table_name|url|expire|processor
  Example:
    badhosts_drop|https://example/json|90d|json_cidr

EOF
}

# =============================================================================
# parse_args
# =============================================================================
# Purpose: Parse CLI flags. Set globals. Enforce debug behavior.
# =============================================================================
parse_args() {
  while [ ${#} -gt 0 ]; do                                        # Loop args
    case "${1}" in
      -h|--help) print_usage; exit 0 ;;                           # Help
      -d|--debug) DEBUG_MODE=true; LOG_LEVEL=3; shift ;;          # Debug mode
      -v|--verbose) LOG_LEVEL=2; shift ;;                         # Verbose
      -q|--quiet) LOG_LEVEL=1; shift ;;                           # Quiet
      -l|--log-level) [ -n "${2:-}" ] && echo "${2}" | grep -E -q '^[0-3]$' && LOG_LEVEL="${2}" && shift 2 || { log 0 "Invalid log level"; exit 1; } ;;  # Level
      -t|--timeout) [ -n "${2:-}" ] && echo "${2}" | grep -E -q '^[0-9]+$' && DOWNLOAD_TIMEOUT="${2}" && shift 2 || { log 0 "Invalid timeout"; exit 1; } ;;  # Timeout
      -r|--retries) [ -n "${2:-}" ] && echo "${2}" | grep -E -q '^[0-9]+$' && DOWNLOAD_RETRIES="${2}" && shift 2 || { log 0 "Invalid retries"; exit 1; } ;; # Retries
      -j|--threads) [ -n "${2:-}" ] && echo "${2}" | grep -E -q '^[0-9]+$' && PROCESSING_THREADS="${2}" && shift 2 || { log 0 "Invalid threads"; exit 1; } ;; # Threads
      --dry-run) DRY_RUN=true; shift ;;                           # Dry-run
      --config) [ -n "${2:-}" ] && CONFIG_FILE="${2}" && shift 2 || { log 0 "--config requires argument"; exit 1; } ;;  # Config
      --log-format) [ -n "${2:-}" ] && (echo "${2}" | grep -E -q '^(text|json)$') && LOG_FORMAT="${2}" && shift 2 || { log 0 "Invalid log-format"; exit 1; } ;; # Format
      --no-color) USE_COLORS=false; shift ;;                      # Colors off
      --self-test) SELF_TEST_REQUESTED="1"; shift ;;              # Self-test
      *) log 0 "Unknown option: ${1}"; print_usage; exit 1 ;;     # Unknown
    esac
  done
  if [ "${DEBUG_MODE}" = true ]; then                             # Debug tweaks
    TABLE_DEFAULT_EXPIRE="3600";                                  # 1 hour TTL
    log 2 "Debug mode: using 1-hour expiry"                       # Info
  fi
  log 2 "Configured: log_level=${LOG_LEVEL} timeout=${DOWNLOAD_TIMEOUT}s retries=${DOWNLOAD_RETRIES} threads=${PROCESSING_THREADS}"  # Summary
}

# =============================================================================
# validate_input
# =============================================================================
# Purpose: Validate core numeric inputs.
# =============================================================================
validate_input() {
  echo "${LOG_LEVEL}" | grep -E -q '^[0-3]$' || { log 0 "Invalid log level"; return 1; }  # Level check
  echo "${DOWNLOAD_TIMEOUT}" | grep -E -q '^[0-9]+$' || { log 0 "Invalid timeout"; return 1; }  # Timeout check
  echo "${DOWNLOAD_RETRIES}" | grep -E -q '^[0-9]+$' || { log 0 "Invalid retries"; return 1; }  # Retries check
  [ "${PROCESSING_THREADS}" -ge 1 ] 2>/dev/null || { log 0 "Invalid threads"; return 1; }  # Threads check
  return 0                                                         # OK
}

# =============================================================================
# validate_dependencies
# =============================================================================
# Purpose: Ensure required tools exist. Log optional tool presence.
# =============================================================================
validate_dependencies() {
  set -- "pfctl" "awk" "grep" "sed" "date" "file" "fetch" "whois" "lockf"  # Required
  for tool in "${@}"; do
    if ! command -v "${tool}" >/dev/null 2>&1; then
      log 0 "Required tool not found: ${tool}"; return 2                   # Fail early
    fi
  done
  set -- "jq" "expiretable" "curl" "gzip" "brotli" "zstd" "bzip2" "xz"     # Optional
  for tool in "${@}"; do
    if command -v "${tool}" >/dev/null 2>&1; then log 3 "Optional tool found: ${tool}"; else log 2 "Optional tool not found: ${tool}"; fi  # Report
  done
  return 0                                                                 # OK
}

# =============================================================================
# load_config_file
# =============================================================================
# Purpose: Source config file to override defaults, including SOURCES.
# =============================================================================
load_config_file() {
  if [ -f "${CONFIG_FILE}" ]; then                              # Exists?
    log 2 "Loading configuration from ${CONFIG_FILE}"            # Info
    if . "${CONFIG_FILE}" 2>/dev/null; then                     # Source
      log 2 "Config sourced successfully"                        # Info
      PROVIDE_DEFAULT_SOURCES=""                                 # Disable defaults
    else
      log 1 "Warning: Failed to source ${CONFIG_FILE}"           # Warn
    fi
  else
    log 2 "No config file at ${CONFIG_FILE}; using default SOURCES" # Info
  fi
}

# =============================================================================
# self_test
# =============================================================================
# Purpose: Minimal unit tests for parsing, rotation, and diff logic.
# =============================================================================
self_test() {
  failures="0"; passes="0"                                       # Counters
  _ok() { passes="$((passes+1))"; log 2 "TEST PASS: ${1}"; }     # Pass
  _ng() { failures="$((failures+1))"; log 0 "TEST FAIL: ${1}"; } # Fail

  [ "$(convert_to_seconds 1d)" = "86400" ] && _ok "convert 1d" || _ng "convert 1d"   # TTL
  [ "$(convert_to_seconds 2h)" = "7200" ] && _ok "convert 2h" || _ng "convert 2h"    # TTL
  [ "$(convert_to_seconds 30m)" = "1800" ] && _ok "convert 30m" || _ng "convert 30m" # TTL
  [ "$(convert_to_seconds 45s)" = "45" ] && _ok "convert 45s" || _ng "convert 45s"   # TTL
  [ "$(convert_to_seconds "")" = "${TABLE_DEFAULT_EXPIRE}" ] && _ok "convert empty" || _ng "convert empty" # TTL

  # IPv4/IPv6 validators quick checks
  printf '1.2.3.4\n10.0.0.1\n2001:db8::1\nfd00::1\n' | extract_and_filter_ips > "${TMP_DIR}/_t1" 2>/dev/null  # Run filter
  grep -q '^1\.2\.3\.4$' "${TMP_DIR}/_t1" && _ok "ipv4 accept" || _ng "ipv4 accept"  # Check accept
  ! grep -q '^10\.0\.0\.1$' "${TMP_DIR}/_t1" && _ok "ipv4 private reject" || _ng "ipv4 private reject"  # Reject
  ! grep -q '^2001:db8::1$' "${TMP_DIR}/_t1" && _ok "ipv6 doc reject" || _ng "ipv6 doc reject"          # Reject
  ! grep -q '^fd00::1$' "${TMP_DIR}/_t1" && _ok "ipv6 ULA reject" || _ng "ipv6 ULA reject"              # Reject

  # Log rotation smoke: create > threshold and rotate
  echo "X" | awk -v n=200000 '{for(i=0;i<n;i++) print $0}' > "${LOG_FILE}" 2>/dev/null || true  # Inflate
  rotate_logs_if_needed                                                                 # Trigger
  [ -f "${LOG_FILE}" ] && _ok "log rotate exists" || _ng "log rotate exists"            # Check

  log 2 "Self-test done: passes=${passes} failures=${failures}"  # Summary
  [ "${failures}" -eq 0 ]                                        # Return
}

# =============================================================================
# main
# =============================================================================
# Purpose:
#   Entry point. Parse args, validate, load config, iterate sources, process,
#   update PF tables atomically, show PF stats, cleanup safely.
# =============================================================================
main() {
  set -o errexit                                                 # Exit on error
  set -o nounset                                                 # Treat unset as error
  (set -o pipefail) 2>/dev/null && set -o pipefail               # Pipefail if supported
  PATH="/usr/bin:/bin:/usr/sbin:/sbin:/usr/local/bin:/usr/local/sbin"; export PATH  # PATH
  export LC_ALL=C; export TZ=UTC                                 # Stable parsing
  trap 'rc=${?}; rm -rf "${TMP_DIR}" >/dev/null 2>&1 || true; exit ${rc}' EXIT INT TERM HUP  # Cleanup trap

  parse_args "${@}"                                              # CLI parse
  validate_input || { log 0 "Input validation failed"; exit 1; } # Validate
  load_config_file                                               # Load config
  mkdir -p "${CACHE_FILES_DIR}" "${CACHE_ETAG_DIR}" >/dev/null 2>&1 || true  # Ensure caches

  validate_dependencies || { log 0 "Dependency validation failed"; exit 2; } # Check deps

  : > "${LOG_FILE}"; echo "=== Starting ${PROG_NAME} at $(date) ===" >> "${LOG_FILE}"  # Start banner
  : > "${METRICS_FILE}"                                           # Reset metrics

  # Establish sources: config SOURCES overrides defaults.
  if [ -z "${SOURCES:-}" ] && [ -n "${PROVIDE_DEFAULT_SOURCES}" ]; then
    SOURCES="${DEFAULT_SOURCES}"                                  # Use default
  fi

  # Iterate sources
  echo "${SOURCES}" | while IFS= read -r entry || [ -n "${entry}" ]; do
    echo "${entry}" | grep -E -q '^[[:space:]]*$' && continue     # Skip blanks
    echo "${entry}" | grep -E -q '^[[:space:]]*#' && continue     # Skip comments
    table_name="$(printf '%s' "${entry}" | awk -F'|' '{print $1}')"  # Field 1
    url="$(printf '%s' "${entry}" | awk -F'|' '{print $2}')"         # Field 2
    expire="$(printf '%s' "${entry}" | awk -F'|' '{print $3}')"      # Field 3
    processor="$(printf '%s' "${entry}" | awk -F'|' '{print $4}')"   # Field 4
    [ -z "${processor}" ] && processor="plain"                    # Default processor

    table_header "${table_name}"                                  # Section
    table_backup "${table_name}"                                  # Backup

    tmp_in="${TMP_DIR}/${table_name}.input"                       # Input path

    case "${processor}" in                                        # Dispatch
      plain)
        if ! download_file "${url}" "${tmp_in}" "${table_name}"; then log 1 "Download failed for ${url}"; : > "${tmp_in}"; fi  # File or empty
        ;;
      json_cidr)
        tmp_json="${TMP_DIR}/${table_name}.json"                  # JSON path
        if download_file "${url}" "${tmp_json}" "${table_name}"; then
          json_extract_key_value "${tmp_json}" "${tmp_in}" "cidr" || : > "${tmp_in}"  # Extract or empty
        else
          : > "${tmp_in}"                                         # Empty
        fi
        ;;
      json_asn)
        tmp_json="${TMP_DIR}/${table_name}.json"                  # JSON path
        tmp_asn="${TMP_DIR}/${table_name}.asn"                    # ASN path
        tmp_asn_ip="${TMP_DIR}/${table_name}.asntoip"             # Routes path
        if download_file "${url}" "${tmp_json}" "${table_name}"; then
          json_extract_key_value "${tmp_json}" "${tmp_asn}" "asn" || : > "${tmp_asn}"  # Extract ASN
          if [ -f "${tmp_asn}" ]; then awk '/^[0-9]+/ {print "AS" $1}' "${tmp_asn}" 2>/dev/null || true; fi  # Echo for visibility
          asn_to_ips "${tmp_asn}" "${tmp_asn_ip}" || : > "${tmp_asn_ip}"  # Resolve
          cat "${tmp_asn_ip}" > "${tmp_in}" 2>/dev/null || : > "${tmp_in}" # Feed input
        else
          : > "${tmp_in}"                                         # Empty
        fi
        ;;
      mail_awk)
        tmp_mail="${TMP_DIR}/${table_name}.raw"                   # Raw log path
        if download_file "${url}" "${tmp_mail}" "${table_name}"; then
          OLDIFS="${IFS}"; IFS='
'
          for string in ${mail_awk_rules}; do logfile_extract_ips "${tmp_mail}" "${tmp_in}" "${string}"; done  # Extract by patterns
          IFS="${OLDIFS}"
        else
          : > "${tmp_in}"                                         # Empty
        fi
        ;;
      sshd_awk)
        tmp_sshd="${TMP_DIR}/${table_name}.raw"                   # Raw log path
        if download_file "${url}" "${tmp_sshd}" "${table_name}"; then
          OLDIFS="${IFS}"; IFS='
'
          for string in ${sshd_awk_rules}; do logfile_extract_ips "${tmp_sshd}" "${tmp_in}" "${string}"; done  # Extract by patterns
          IFS="${OLDIFS}"
        else
          : > "${tmp_in}"                                         # Empty
        fi
        ;;
      *)
        log 1 "Unknown processor '${processor}' for ${table_name}; skipping"; : > "${tmp_in}"  # Warn+skip
        ;;
    esac

    table_process "${table_name}" "${tmp_in}"                     # Validate list
    table_update "${table_name}" "${expire}"                      # Atomic update
    table_footer "${table_name}"                                  # Footer
  done

  log 2 "================================================================================"  # Section
  log 2 "PF Statistics"                                            # Title
  log 2 "================================================================================"  # Separator
  pfctl -v -v -s all || true                                       # PF stats
  log 2 ""                                                         # Spacer
  log 2 "================================================================================"  # End

  if [ "${DRY_RUN}" = true ]; then log 2 "DRY RUN MODE: no changes applied"; else log 2 "Script completed"; fi  # Final msg
}

# =============================================================================
# Entrypoint guard
# =============================================================================
if [ "${0##*/}" = "${PROG_NAME}" ]; then                          # Direct run?
  if [ -n "${SELF_TEST_REQUESTED:-}" ]; then                      # Self-test?
    self_test || exit 1                                           # Run tests
  else
#    with_global_lock main "${@}"                                  # Run under lock
    main "${@}"                                                   # Run under lock
  fi
fi

exit 0                                                            # EOF