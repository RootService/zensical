#!/bin/sh
set -eu
# =============================================================================
# update-pftables
# =============================================================================
#
# Hardened PF table updater for FreeBSD 15
#
# Features:
#   - FreeBSD 15 compatible
#   - POSIX sh only
#   - lockf single-instance protection
#   - atomic PF table replacement
#   - IPv4 + IPv6 support
#   - Spamhaus ASN expansion
#   - ETag HTTP caching
#   - automatic log rotation
#   - safe temporary file handling
#   - strict error handling
#   - multi-source table aggregation
#
# =============================================================================

PROG_NAME="$(basename "$0")"

umask 077

PATH="/usr/bin:/bin:/usr/sbin:/sbin:/usr/local/bin:/usr/local/sbin"
export PATH

export LC_ALL=C
export TZ=UTC

LOCK_FILE="/var/run/${PROG_NAME}.lock"

###############################################################################
# SINGLE INSTANCE LOCK
###############################################################################

if [ "${1:-}" != "--locked" ]; then
    exec lockf -ks -t 0 "${LOCK_FILE}" "$0" --locked "$@"
fi
shift

###############################################################################
# TEMP DIRECTORY
###############################################################################

TMP_DIR="$(mktemp -d -t "${PROG_NAME}")"

cleanup() {
    rc=$?

    rm -rf "${TMP_DIR}" >/dev/null 2>&1 || true

    exit "${rc}"
}

trap cleanup EXIT INT TERM HUP

###############################################################################
# CACHE
###############################################################################

CACHE_DIR="/var/cache/${PROG_NAME}"
CACHE_FILES_DIR="${CACHE_DIR}/files"
CACHE_ETAG_DIR="${CACHE_DIR}/etag"

mkdir -p "${CACHE_FILES_DIR}" "${CACHE_ETAG_DIR}"

###############################################################################
# TABLE AGGREGATION
###############################################################################

TABLE_AGGREGATE_DIR="${TMP_DIR}/aggregate"

mkdir -p "${TABLE_AGGREGATE_DIR}"

###############################################################################
# LOGGING
###############################################################################

LOG_LEVEL="2"
LOG_FILE="/var/log/${PROG_NAME}.log"

USE_COLORS=false
[ -t 1 ] && USE_COLORS=true

MAX_LOG_SIZE_BYTES="1048576"

rotate_logs_if_needed() {

    [ -f "${LOG_FILE}" ] || return 0

    size_bytes="$(wc -c < "${LOG_FILE}" 2>/dev/null || echo 0)"

    case "${size_bytes}" in
        ''|*[!0-9]*)
            return 0
            ;;
    esac

    if [ "${size_bytes}" -lt "${MAX_LOG_SIZE_BYTES}" ]; then
        return 0
    fi

    ts="$(date '+%Y%m%d%H%M%S')"

    mv -f \
        "${LOG_FILE}" \
        "${LOG_FILE}.${ts}" \
        >/dev/null 2>&1 || return 0

    : > "${LOG_FILE}"

    chmod 600 "${LOG_FILE}"

    if command -v gzip >/dev/null 2>&1; then
        gzip -9f "${LOG_FILE}.${ts}" >/dev/null 2>&1 || true
    fi
}

log() {

    level="${1}"
    shift

    [ "${level}" -le "${LOG_LEVEL}" ] || return 0

    rotate_logs_if_needed

    case "${level}" in
        0) msg_type="ERROR" ;;
        1) msg_type="WARN " ;;
        2) msg_type="INFO " ;;
        3) msg_type="DEBUG" ;;
        *) msg_type="INFO " ;;
    esac

    if [ "${USE_COLORS}" = true ]; then

        case "${level}" in
            0) color="$(printf '\033[1;31m')" ;;
            1) color="$(printf '\033[1;33m')" ;;
            2) color="$(printf '\033[1;36m')" ;;
            3) color="$(printf '\033[1;35m')" ;;
            *) color="" ;;
        esac

        reset_color="$(printf '\033[0m')"

    else

        color=""
        reset_color=""
    fi

    timestamp="$(date '+%Y-%m-%d %H:%M:%S')"

	log_line="$(printf '%s %s%s%s: %s\n' \
		"${timestamp}" \
		"${color}" \
		"${msg_type}" \
		"${reset_color}" \
		"$*")"

    printf '%s\n' "${log_line}" >&2 || true

    printf '%s\n' "${log_line}" >> "${LOG_FILE}" 2>/dev/null || true
}

###############################################################################
# GLOBAL CONFIG
###############################################################################

DEBUG_MODE=false
DRY_RUN=false

DOWNLOAD_TIMEOUT="30"
DOWNLOAD_RETRIES="3"

TABLE_DEFAULT_EXPIRE="86400"

WHOIS_POLITE_DELAY_SECONDS="0.1"

CONFIG_FILE="/usr/local/etc/${PROG_NAME}.conf"

###############################################################################
# SOURCES
###############################################################################

DEFAULT_SOURCES='
badhosts_drop|https://www.spamhaus.org/drop/drop_v4.json|90d|json_cidr
badhosts_drop|https://www.spamhaus.org/drop/drop_v6.json|90d|json_cidr
badhosts_drop|https://www.spamhaus.org/drop/asndrop.json|90d|json_asn
badhosts_torp|https://www.dan.me.uk/torlist/?full|2d|plain
badhosts_misc|https://lists.blocklist.de/lists/all.txt|2d|plain
badhosts_scan|file:///etc/pf.badhosts_scan|7d|plain
badhosts_dns|file:///etc/pf.badhosts_dns|7d|plain
badhosts_ntpd|file:///etc/pf.badhosts_ntpd|7d|plain
badhosts_http|file:///etc/pf.badhosts_http|7d|plain
badhosts_priv|file:///etc/pf.badhosts_priv|30d|plain
'

###############################################################################
# HELPERS
###############################################################################

url_to_safe_name() {

    printf '%s' "${1}" |
    sed 's/[^A-Za-z0-9._-]/_/g' |
    cut -c1-180
}

convert_to_seconds() {

    expire_time="${1:-}"

    [ -z "${expire_time}" ] && {
        echo "${TABLE_DEFAULT_EXPIRE}"
        return 0
    }

    number="$(printf '%s' "${expire_time}" | sed 's/[^0-9]//g')"
    unit="$(printf '%s' "${expire_time}" | sed 's/[0-9]*//g')"

    [ -z "${number}" ] && {
        echo "${TABLE_DEFAULT_EXPIRE}"
        return 0
    }

    case "${unit}" in
        d) echo "$((number * 86400))" ;;
        h) echo "$((number * 3600))" ;;
        m) echo "$((number * 60))" ;;
        s|'') echo "${number}" ;;
        *) echo "${TABLE_DEFAULT_EXPIRE}" ;;
    esac
}

###############################################################################
# IP VALIDATION
###############################################################################

validate_ip_with_ipcalc() {

    candidate="${1}"

    case "${candidate}" in
        *:*)
            ipcalc -6 -c "${candidate}" >/dev/null 2>&1
            ;;
        *)
            ipcalc -4 -c "${candidate}" >/dev/null 2>&1
            ;;
    esac
}

is_excluded_ip() {

    ip="${1}"

    case "${ip}" in
        0.*|10.*|127.*|169.254.*|192.168.*)
            return 0
            ;;
        172.1[6-9].*|172.2[0-9].*|172.3[0-1].*)
            return 0
            ;;
        ::1|fc*|fd*|fe8*|fe9*|fea*|feb*)
            return 0
            ;;
        ::|fe[c-f]*|ff[0-9a-fA-F]*|2001:db8:*)
            return 0
            ;;
    esac

    return 1
}

extract_and_filter_ips() {

    while IFS= read -r line; do

        printf '%s\n' "${line}" |
        tr ' ,;()[]{}<>' '\n' |
        while IFS= read -r token; do

            [ -n "${token}" ] || continue

            validate_ip_with_ipcalc "${token}" || continue

            is_excluded_ip "${token}" && continue

            printf '%s\n' "${token}"

        done

    done
}

###############################################################################
# DOWNLOAD
###############################################################################

download_file() {

    url="${1}"
    output_file="${2}"

    tempfile="$(mktemp "${TMP_DIR}/download.XXXXXX")"

    safe="$(url_to_safe_name "${url}")"

    cached_file="${CACHE_FILES_DIR}/${safe}.cache"
    etag_file="${CACHE_ETAG_DIR}/${safe}.etag"

    case "${url}" in
        file://*)

            local_path="$(printf '%s' "${url}" | sed 's|^file://||')"

            [ -f "${local_path}" ] || {
                log 1 "Missing local file: ${local_path}"
                rm -f "${tempfile}"
                return 1
            }

            cp -f "${local_path}" "${output_file}"

            rm -f "${tempfile}"

            return 0
            ;;
    esac

    http_code="$(curl \
        --silent \
        --show-error \
        --location \
        --compressed \
        --retry "${DOWNLOAD_RETRIES}" \
        --retry-delay 2 \
        --retry-connrefused \
        --max-time "${DOWNLOAD_TIMEOUT}" \
        --output "${tempfile}" \
        --write-out "%{http_code}" \
        $( [ -f "${etag_file}" ] && printf -- '--etag-compare %s' "${etag_file}" ) \
        $( printf -- '--etag-save %s' "${etag_file}" ) \
        "${url}" 2>/dev/null || echo 000)"

    case "${http_code}" in

        200)

            mv -f "${tempfile}" "${cached_file}"

            cp -f "${cached_file}" "${output_file}"

            log 2 "Downloaded: ${url} (HTTP ${http_code})"
            ;;

        304)

            if [ -f "${cached_file}" ]; then

                cp -f "${cached_file}" "${output_file}"

                log 2 "Using cache: ${url}"

            else

                rm -f "${tempfile}"

                log 1 "Missing cache file: ${url}"

                return 1
            fi
            ;;

        *)

            rm -f "${tempfile}"

            log 1 "Download failed: ${url} (HTTP ${http_code})"

            return 1
            ;;
    esac

    return 0
}

###############################################################################
# JSON
###############################################################################

json_extract_key_value() {

    input_file="${1}"
    output_file="${2}"
    key="${3}"

    jq -r --arg k "${key}" '
        .. | objects | .[$k]? // empty
    ' "${input_file}" > "${output_file}"
}

###############################################################################
# ASN
###############################################################################

asn_to_ips() {

    input_file="${1}"
    output_file="${2}"

    : > "${output_file}"

    [ -f "${input_file}" ] || return 0

    while IFS= read -r asn; do

        [ -z "${asn}" ] && continue

        whois -h whois.radb.net -- "-i origin ${asn}" 2>/dev/null |
        awk '
            /^route:/  { print $2 }
            /^route6:/ { print $2 }
        '

        sleep "${WHOIS_POLITE_DELAY_SECONDS}"

    done < "${input_file}" | sort -u > "${output_file}"

    if [ ! -s "${output_file}" ]; then
        log 1 "No IP addresses found for AS numbers in ${input_file}"
        return 1
    fi

    log 2 "Converted AS numbers to IPs: $(wc -l < "${output_file}") entries"

    return 0
}

###############################################################################
# TABLE PROCESSING
###############################################################################

table_process() {

    table_name="${1}"
    input_file="${2}"

    output="${TMP_DIR}/${table_name}"

    : > "${output}"

    extract_and_filter_ips < "${input_file}" |
    sort -u > "${output}"

    count="$(wc -l < "${output}" 2>/dev/null || echo 0)"

    log 2 "Processed ${count} entries for ${table_name}"
}

aggregate_table_entries() {

    table_name="${1}"
    source_file="${2}"

    aggregate_file="${TABLE_AGGREGATE_DIR}/${table_name}"

    [ -f "${source_file}" ] || return 0

    cat "${source_file}" >> "${aggregate_file}"
}

table_exists() {

    table_name="${1}"

    pfctl -s Tables 2>/dev/null |
    awk '{print $1}' |
    grep -Fxq "${table_name}"
}

finalize_table() {

    table_name="${1}"
    expire_time="${2}"

    aggregate_file="${TABLE_AGGREGATE_DIR}/${table_name}"
    final_file="${TMP_DIR}/${table_name}.final"

    [ -f "${aggregate_file}" ] || {
        log 1 "No aggregate data for ${table_name}"
        return 1
    }

    sort -u "${aggregate_file}" > "${final_file}"

    count="$(wc -l < "${final_file}" 2>/dev/null || echo 0)"

    log 2 "Finalized ${table_name}: ${count} unique entries"

    if [ "${DRY_RUN}" = true ]; then
        log 2 "DRY RUN: ${table_name}"
        return 0
    fi

    if ! table_exists "${table_name}"; then
        log 1 "PF table does not exist: ${table_name}"
        return 1
    fi

    if ! pfctl -t "${table_name}" -T replace -f "${final_file}" >/dev/null 2>&1; then
        log 0 "Failed replacing PF table: ${table_name}"
        return 1
    fi

    ttl="$(convert_to_seconds "${expire_time}")"

    pfctl -t "${table_name}" -T expire "${ttl}" >/dev/null 2>&1 || true

    log 2 "PF table updated: ${table_name}"
}

###############################################################################
# UI
###############################################################################

table_header() {

    log 2 "================================================================================"
    log 2 "Table ${1}"
    log 2 "================================================================================"
}

table_footer() {

    log 2 "================================================================================"
}

###############################################################################
# CONFIG
###############################################################################

parse_args() {

    while [ $# -gt 0 ]; do

        case "${1}" in

            -d|--debug)

                DEBUG_MODE=true
                LOG_LEVEL=3
                shift
                ;;

            --dry-run)

                DRY_RUN=true
                shift
                ;;

            --config)

                [ -n "${2:-}" ] || {
                    echo "--config requires argument" >&2
                    exit 1
                }

                CONFIG_FILE="${2}"

                shift 2
                ;;

            *)

                echo "Unknown argument: ${1}" >&2
                exit 1
                ;;
        esac
    done
}

load_config_file() {

    if [ -f "${CONFIG_FILE}" ]; then
        . "${CONFIG_FILE}"
    else
        SOURCES="${DEFAULT_SOURCES}"
    fi
}

###############################################################################
# VALIDATION
###############################################################################

validate_environment() {

    for tool in \
        pfctl \
        awk \
        grep \
        sed \
        curl \
        jq \
        whois \
        ipcalc \
        lockf
    do
        command -v "${tool}" >/dev/null 2>&1 || {
            echo "Missing tool: ${tool}" >&2
            exit 1
        }
    done

    if ! kldstat -q -m pf; then
        log 0 "PF kernel module is not loaded"
        exit 1
    fi

    if ! pfctl -s info >/dev/null 2>&1; then
        log 0 "PF is not operational"
        exit 1
    fi
}

###############################################################################
# MAIN
###############################################################################

main() {

    parse_args "$@"

    load_config_file

    [ -n "${SOURCES:-}" ] || {
        log 0 "No SOURCES configured"
        exit 1
    }

    validate_environment

    while IFS= read -r entry || [ -n "${entry}" ]; do

        [ -z "${entry}" ] && continue

        table_name="$(printf '%s\n' "${entry}" | awk -F'|' '{print $1}')"
        url="$(printf '%s\n' "${entry}" | awk -F'|' '{print $2}')"
        expire="$(printf '%s\n' "${entry}" | awk -F'|' '{print $3}')"
        processor="$(printf '%s\n' "${entry}" | awk -F'|' '{print $4}')"

        tmp_in="${TMP_DIR}/${table_name}.input"

        table_header "${table_name}"

        case "${processor}" in

            plain)

                download_file "${url}" "${tmp_in}" || {
                    log 1 "Skipping table ${table_name}"
                    table_footer
                    continue
                }
                ;;

            json_cidr)

                tmp_json="${TMP_DIR}/${table_name}.json"

                download_file "${url}" "${tmp_json}" || {
                    log 1 "Skipping table ${table_name}"
                    table_footer
                    continue
                }

                json_extract_key_value \
                    "${tmp_json}" \
                    "${tmp_in}" \
                    "cidr"
                ;;

            json_asn)

                tmp_json="${TMP_DIR}/${table_name}.json"
                tmp_asn="${TMP_DIR}/${table_name}.asn"
                tmp_asn_ip="${TMP_DIR}/${table_name}.asntoip"

                download_file "${url}" "${tmp_json}" || {
                    log 1 "Skipping table ${table_name}"
                    table_footer
                    continue
                }

                json_extract_key_value \
                    "${tmp_json}" \
                    "${tmp_asn}" \
                    "asn"

                awk '
                    {
                        gsub(/[^0-9]/, "", $0)

                        if ($0 ~ /^[0-9]+$/)
                            print "AS" $0
                    }
                ' "${tmp_asn}" |
                sort -u > "${tmp_asn}.clean"

                asn_to_ips \
                    "${tmp_asn}.clean" \
                    "${tmp_asn_ip}" || {
                    log 1 "ASN expansion failed for ${table_name}"
                    table_footer
                    continue
                }

                cp -f "${tmp_asn_ip}" "${tmp_in}"
                ;;

            *)

                log 1 "Unknown processor: ${processor}"

                table_footer

                continue
                ;;
        esac

        table_process "${table_name}" "${tmp_in}"

        aggregate_table_entries \
            "${table_name}" \
            "${TMP_DIR}/${table_name}"

        table_footer

    done <<EOF
${SOURCES}
EOF

    done_tables="$(
        find "${TABLE_AGGREGATE_DIR}" \
            -type f \
            -exec basename {} \; |
        sort -u
    )"

    for table_name in ${done_tables}; do

        expire="$(
            printf '%s\n' "${SOURCES}" |
            awk -F'|' -v t="${table_name}" '
                $1 == t {
                    print $3
                    exit
                }
            '
        )"

        finalize_table \
            "${table_name}" \
            "${expire}" || true
    done

    log 2 "Script completed"
}

###############################################################################
# ENTRYPOINT
###############################################################################

main "${@}"

exit $?