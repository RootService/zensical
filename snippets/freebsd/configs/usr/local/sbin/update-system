#!/bin/sh
set -eu

# =============================================================================
# update-system
# =============================================================================

SCRIPT_NAME="${0##*/}"

MODE="ports"

SKIP_CONFIRM=false
VERBOSE=false
DRY_RUN=false

CONFIG_FILE="/usr/local/etc/update-system.conf"

LOG_DIR="/var/log"
LOG_FILE="${LOG_DIR}/update-system.log"

LOCK_DIR="/var/run/update-system.lock"

PORTS_DIR="/usr/ports"

TMP_DIR="$(mktemp -d -t update-system.XXXXXX)"

# =============================================================================
# Logging
# =============================================================================

init_logging() {
    touch "$LOG_FILE"

    exec 3>>"$LOG_FILE"
}

log() {
    level="$1"
    shift

    case "$level" in
        0) msg_type="ERROR" ;;
        1) msg_type="WARN " ;;
        2) msg_type="INFO " ;;
        3) msg_type="DEBUG" ;;
        *) msg_type="INFO " ;;
    esac

    timestamp="$(date '+%Y-%m-%d %H:%M:%S')"

    line="${timestamp} ${msg_type}: $*"

    printf '%s\n' "$line"
    printf '%s\n' "$line" >&3
}

debug() {
    [ "$VERBOSE" = true ] || return 0
    log 3 "$@"
}

# =============================================================================
# Usage
# =============================================================================

print_usage() {
    cat <<EOF
Usage: $SCRIPT_NAME [OPTIONS]

Options:
  -h, --help              Show help
  -m, --mode MODE         ports | packages
  -y, --yes               Skip confirmation
  -v, --verbose           Verbose mode
  -d, --dry-run           Dry-run mode
  --config FILE           Configuration file

Examples:
  $SCRIPT_NAME
  $SCRIPT_NAME -m packages
  $SCRIPT_NAME -m ports -y
  $SCRIPT_NAME -d

EOF
}

# =============================================================================
# Args
# =============================================================================

parse_args() {
    while [ $# -gt 0 ]; do
        case "$1" in
            -h|--help)
                print_usage
                exit 0
                ;;

            -m|--mode)
                [ $# -ge 2 ] || {
                    log 0 "--mode requires argument"
                    exit 1
                }

                case "$2" in
                    ports|packages)
                        MODE="$2"
                        ;;
                    *)
                        log 0 "Invalid mode: $2"
                        exit 1
                        ;;
                esac

                shift 2
                ;;

            -y|--yes)
                SKIP_CONFIRM=true
                shift
                ;;

            -v|--verbose)
                VERBOSE=true
                shift
                ;;

            -d|--dry-run)
                DRY_RUN=true
                SKIP_CONFIRM=true
                shift
                ;;

            --config)
                [ $# -ge 2 ] || {
                    log 0 "--config requires argument"
                    exit 1
                }

                CONFIG_FILE="$2"
                shift 2
                ;;

            *)
                log 0 "Unknown option: $1"
                exit 1
                ;;
        esac
    done
}

# =============================================================================
# Config
# =============================================================================

load_config() {
    [ -f "$CONFIG_FILE" ] || return 0

    log 2 "Loading config: $CONFIG_FILE"

    # shellcheck disable=SC1090
    . "$CONFIG_FILE"
}

# =============================================================================
# Locking
# =============================================================================

acquire_lock() {
    if ! mkdir "$LOCK_DIR" 2>/dev/null; then
        log 0 "Another update-system instance is running"
        exit 1
    fi

    echo "$$" > "${LOCK_DIR}/pid"
}

release_lock() {
    rm -rf "$LOCK_DIR" >/dev/null 2>&1 || true
}

# =============================================================================
# Validation
# =============================================================================

require_command() {
    command -v "$1" >/dev/null 2>&1 || {
        log 0 "Missing command: $1"
        return 1
    }
}

validate_environment() {
    log 2 "Validating environment"

    for cmd in git make pkg awk df pgrep; do
        require_command "$cmd"
    done

    if [ "$MODE" = "ports" ]; then
        require_command portmaster
    fi

    [ -d "$PORTS_DIR" ] || {
        log 0 "Ports tree missing: $PORTS_DIR"
        return 1
    }

    free_space="$(df -m "$PORTS_DIR" | awk 'NR==2 {print $4}')"

    if [ "$free_space" -lt 512 ]; then
        log 1 "Low disk space: ${free_space}MB"
    fi

    return 0
}

# =============================================================================
# Health Checks
# =============================================================================

health_check() {
    log 2 "Running health checks"

    if git -C "$PORTS_DIR" status --porcelain | grep -q .; then
        log 1 "Ports tree contains local modifications"
    fi

    if pgrep -f 'pkg.*(upgrade|install|delete)' >/dev/null 2>&1; then
        log 1 "pkg activity detected"
    fi

    if pgrep -f 'portmaster|poudriere|synth' >/dev/null 2>&1; then
        log 1 "Ports build activity detected"
    fi

    return 0
}

# =============================================================================
# Preparation
# =============================================================================

prepare_update() {
    log 2 "Preparing update"

    if [ "$DRY_RUN" = true ]; then
        log 2 "DRY RUN: git pull --ff-only"
        log 2 "DRY RUN: make fetchindex"
        log 2 "DRY RUN: pkg update"
        return 0
    fi

    log 2 "Updating ports tree"

    git -C "$PORTS_DIR" pull --ff-only || {
        log 0 "git pull failed"
        return 1
    }

    log 2 "Fetching INDEX"

    make -C "$PORTS_DIR" fetchindex || {
        log 1 "fetchindex failed"
    }

    log 2 "Updating pkg repositories"

    pkg update || {
        log 0 "pkg update failed"
        return 1
    }

    return 0
}

# =============================================================================
# Show Updates
# =============================================================================

show_updates() {
    printf '\n'
    printf '===============================================================================\n'

    case "$MODE" in
        packages)
            log 2 "Available package upgrades"
            pkg version -vRl=
            ;;

        ports)
            log 2 "Installed ports requiring updates"
            pkg version -vl '<'
            ;;
    esac

    printf '===============================================================================\n'
    printf '\n'
}

# =============================================================================
# Confirmation
# =============================================================================

confirm_action() {
    [ "$SKIP_CONFIRM" = true ] && return 0

    printf 'Proceed with %s update? [y/N] ' "$MODE"

    read -r answer || return 1

    case "$answer" in
        y|Y|yes|YES)
            return 0
            ;;
    esac

    return 1
}

# =============================================================================
# Ports Updates
# =============================================================================

update_ports() {
    log 2 "Starting ports update"

    if [ "$DRY_RUN" = true ]; then
        log 2 "DRY RUN: portmaster execution"
        return 0
    fi

    PM_ARGS="
        --no-confirm
        --no-term-title
        --index-first
        -w
        -B
        -g
        -a
    "

    if [ "$VERBOSE" = true ]; then
        PM_ARGS="$PM_ARGS -v"
    else
        PM_ARGS="$PM_ARGS -y"
    fi

    # shellcheck disable=SC2086
    portmaster $PM_ARGS || {
        log 0 "portmaster failed"
        return 1
    }

    log 2 "Cleaning distfiles"

    portmaster \
        --no-confirm \
        --clean-distfiles \
        -y || true

    log 2 "Cleaning packages"

    portmaster \
        --no-confirm \
        --clean-packages \
        -y || true

    return 0
}

# =============================================================================
# Package Updates
# =============================================================================

update_packages() {
    log 2 "Starting package update"

    if [ "$DRY_RUN" = true ]; then
        log 2 "DRY RUN: pkg upgrade"
        return 0
    fi

    if [ "$VERBOSE" = true ]; then
        pkg upgrade -y -v
    else
        pkg upgrade -y
    fi

    rc=$?

    [ "$rc" -eq 0 ] || {
        log 0 "pkg upgrade failed"
        return 1
    }

    log 2 "Cleaning package cache"

    pkg clean -ya || true

    return 0
}

# =============================================================================
# Cleanup
# =============================================================================

cleanup() {
    release_lock

    if [ -n "${TMP_DIR:-}" ] && [ -d "$TMP_DIR" ]; then
        rm -rf "$TMP_DIR"
    fi
}

# =============================================================================
# Main
# =============================================================================

main() {
    trap cleanup EXIT INT TERM HUP

    init_logging

    log 2 "=== Starting ${SCRIPT_NAME} ==="

    acquire_lock

    parse_args "$@"

    load_config || {
        log 1 "Failed to load config"
    }

    validate_environment || exit 5

    health_check || true

    prepare_update || exit 2

    show_updates

    confirm_action || {
        log 1 "Operation cancelled"
        exit 1
    }

    case "$MODE" in
        ports)
            update_ports
            ;;
        packages)
            update_packages
            ;;
    esac

    rc=$?

    if [ "$rc" -eq 0 ]; then
        log 2 "Update completed successfully"
    else
        log 0 "Update failed"
    fi

    return "$rc"
}

main "$@"
exit $?